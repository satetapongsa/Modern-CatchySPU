generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Student {
  id        Int      @id @default(autoincrement())
  studentId String   @unique
  name      String
  faculty   String
  slot      String?
  shardedDb String
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  event     String
  loadLevel Int
}
